PORT=8000
# Primary browser origin(s) for your Netlify app (comma-separated allowed).
FRONTEND_URL=http://localhost:5173
# Optional extra CORS origins (comma-separated), e.g. https://deploy-preview-1--mysite.netlify.app
# CORS_EXTRA_ORIGINS=

# CORS regex for Netlify subdomains. Default in code matches https://*.netlify.app
# Set to empty to disable regex matching: CORS_ORIGIN_REGEX=

ANTHROPIC_API_KEY=
APIFY_TOKEN=
RAPIDAPI_KEY=
# Optional: override LinkedIn search (default: Fresh LinkedIn search-employees)
# RAPIDAPI_LINKEDIN_HOST=linkedin-data-max.p.rapidapi.com
# RAPIDAPI_LINKEDIN_PATH=/search

# Firebase: use ONE of the following (JSON is recommended on Render).
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
DEBUG=false
