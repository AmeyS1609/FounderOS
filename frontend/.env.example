# FounderOS frontend — Vite reads only variables prefixed with VITE_.

# Backend API (FounderOS FastAPI). No trailing slash.
# Local development:
VITE_API_BASE_URL=http://127.0.0.1:8000

# Production on Netlify (choose ONE approach):
# (1) Direct: set VITE_API_BASE_URL in Netlify to https://YOUR-SERVICE.up.railway.app (or Render URL)
# (2) Proxy: set Netlify BACKEND_PUBLIC_URL to that same origin (build env), leave VITE unset — see root README

# Legacy / optional — only if you still use Gemini from this template:
# GEMINI_API_KEY=
